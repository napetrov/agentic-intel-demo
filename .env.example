# Sample environment for the local docker-compose bring-up. Copy to .env at
# the repo root and edit; docker compose loads it automatically. Everything
# below is optional unless you opt into the Flowise overlay.
#
#   cp .env.example .env
#   docker compose up --build

# --- MinIO (S3-compatible artifact store) ----------------------------------
# Used by the offload-worker and control-plane. Defaults match the
# in-compose creds; override only if you publish MinIO beyond localhost.
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=minio-dummy-secret-1234

# --- Agent gateway (agent_invoke path) -------------------------------------
# By default `agent_invoke` is forwarded to the in-compose `agent-stub`
# service. Point these at a real OpenClaw gateway to bypass the stub.
# OPENCLAW_GATEWAY_URL=https://openclaw.example.internal
# OPENCLAW_GATEWAY_TOKEN=replace-me

# --- Platform health probes ------------------------------------------------
# The web UI's "Platform health" rail probes these honestly via
# /api/probe/{name}. Leaving them unset shows "unwired" rather than
# falsely reporting OK.
# LITELLM_BASE_URL=http://litellm.example.internal:4000
# SAMBANOVA_PROBE_URL=https://api.sambanova.ai/v1/models

# --- Flowise overlay (docker-compose.flowise.yaml) -------------------------
# Required when running the Flowise overlay; the container fails fast if any
# of these are unset. FLOWISE_SECRETKEY_OVERWRITE encrypts stored
# credentials — generate once (e.g. `openssl rand -hex 32`) and pin.
# FLOWISE_USERNAME=admin
# FLOWISE_PASSWORD=change-me
# FLOWISE_SECRETKEY_OVERWRITE=replace-with-32-byte-hex
# LITELLM_API_KEY=sk-demo-not-a-real-key

# --- OpenWebUI overlay (docker-compose.openwebui.yaml) ---------------------
# Defaults wire OpenWebUI to LiteLLM by service name. Override to target a
# remote OpenAI-compatible endpoint without bringing LiteLLM up locally.
# OPEN_WEBUI_OPENAI_BASE=https://api.openai.com/v1
# OPEN_WEBUI_OPENAI_KEY=sk-...
