{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/napetrov/agentic-intel-demo/schemas/agents.schema.json",
  "title": "Demo agent registry seed",
  "description": "Shape contract for config/agents.yaml. The control plane reads this at startup and surfaces it via GET /agents; the kube backend overlays live cluster discovery on top.",
  "type": "object",
  "required": ["apiVersion", "kind", "agents"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "const": "demo.agents/v1" },
    "kind": { "const": "AgentRegistry" },
    "agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/agent" }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["id", "name", "kind", "system", "capabilities"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 59,
          "pattern": "^[a-z]([a-z0-9-]*[a-z0-9])?$",
          "description": "DNS-1035 compatible id (lower-case start, alphanumeric end, internal dashes only; <=59 chars so `-job` can be appended without exceeding the 63-char k8s label budget)."
        },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["openclaw", "flowise"] },
        "system": { "type": "string", "enum": ["system_a", "system_b"] },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "discovery": { "$ref": "#/$defs/discovery" },
        "confidential": {
          "description": "Optional confidential-computing runtime requirement. When set, the control plane renders the session Pod with the matching runtimeClassName + nodeSelector so the workload is admitted only on a TEE-capable node. Today only `tdx` (Intel Trust Domain Extensions) is wired; the value is an enum so future TEEs (e.g. SGX, SEV-SNP) can be added without an apiVersion bump.",
          "type": "string",
          "enum": ["tdx"]
        }
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openclaw_instance": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "deployment": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "namespace": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "chatflow_id": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        }
      }
    }
  }
}
