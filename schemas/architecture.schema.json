{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/napetrov/agentic-intel-demo/schemas/architecture.schema.json",
  "title": "Demo architecture template",
  "description": "Shape contract for templates/architecture/examples/*/architecture.yaml. Spec-only files: validated here, not consumed by deploy scripts.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "const": "demo.architecture/v1" },
    "kind": { "const": "Architecture" },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
      }
    },
    "spec": {
      "type": "object",
      "required": [
        "topology",
        "components",
        "model_aliases",
        "supported_execution_modes"
      ],
      "additionalProperties": false,
      "properties": {
        "topology": { "$ref": "#/$defs/topology" },
        "components": { "$ref": "#/$defs/components" },
        "model_aliases": { "$ref": "#/$defs/model_aliases" },
        "supported_execution_modes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/execution_mode" },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "execution_mode": {
      "type": "string",
      "enum": ["local_standard", "local_large", "offload_system_b"]
    },
    "topology": {
      "type": "object",
      "required": ["mode", "clusters"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["single_node", "two_system", "multi_system"]
        },
        "clusters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "role", "runtime"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "role": {
                "type": "string",
                "enum": ["orchestration", "execution", "mixed"]
              },
              "runtime": { "type": "string", "enum": ["k3s", "k3d"] }
            }
          }
        }
      }
    },
    "components": {
      "type": "object",
      "required": [
        "orchestrator",
        "model_router",
        "inference_providers",
        "artifact_store",
        "chat_adapters"
      ],
      "additionalProperties": false,
      "properties": {
        "orchestrator": {
          "type": "object",
          "required": ["type", "location"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["openclaw"] },
            "location": { "type": "string", "minLength": 1 }
          }
        },
        "model_router": {
          "type": "object",
          "required": ["type", "location"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["litellm"] },
            "location": { "type": "string", "minLength": 1 }
          }
        },
        "inference_providers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/inference_provider" }
        },
        "execution_backends": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "location", "profile"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "location": { "type": "string", "minLength": 1 },
              "profile": {
                "type": "object",
                "required": ["cpu", "memory"],
                "additionalProperties": false,
                "properties": {
                  "cpu": { "type": ["integer", "string"] },
                  "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" }
                }
              }
            }
          }
        },
        "artifact_store": {
          "type": "object",
          "required": ["type", "location", "bucket"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["minio"] },
            "location": { "type": "string", "minLength": 1 },
            "bucket": { "type": "string", "minLength": 1 }
          }
        },
        "chat_adapters": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["telegram"] },
          "uniqueItems": true
        }
      }
    },
    "inference_provider": {
      "type": "object",
      "required": ["name", "type", "model"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "type": {
          "type": "string",
          "enum": ["vllm", "ollama", "bedrock", "sambanova"]
        },
        "location": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "context_length": { "type": "integer", "minimum": 1 },
        "auth": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "credential_ref": { "type": "string", "minLength": 1 }
      }
    },
    "model_aliases": {
      "type": "object",
      "required": ["default", "fast", "reasoning", "code"],
      "additionalProperties": false,
      "properties": {
        "default": { "type": "string", "minLength": 1 },
        "fast": { "type": "string", "minLength": 1 },
        "reasoning": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 }
      }
    }
  }
}
