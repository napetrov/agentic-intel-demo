apiVersion: v1
kind: Secret
metadata:
  name: intel-demo-operator-secrets
  namespace: default
type: Opaque
stringData:
  TELEGRAM_BOT_TOKEN: "CHANGE_ME_TELEGRAM_BOT_TOKEN"
  AWS_BEARER_TOKEN_BEDROCK: "CHANGE_ME_AWS_BEARER_TOKEN_BEDROCK"
  SAMBANOVA_API_KEY: "CHANGE_ME_SAMBANOVA_API_KEY"
  MINIO_ACCESS_KEY: "CHANGE_ME_MINIO_ACCESS_KEY"
  MINIO_SECRET_KEY: "CHANGE_ME_MINIO_SECRET_KEY"
  # Optional. A GitHub PAT (classic or fine-grained) the OpenClaw instance
  # consumes internally — agents inside the session pod read it as
  # GH_TOKEN / GITHUB_TOKEN to clone private repos, push branches, open
  # PRs via `gh`, and pull private GHCR images referenced by tools. Leave
  # the placeholder if no GitHub access is needed; an empty value makes
  # `gh auth status` fail loudly inside the session pod, which is the
  # intended "unconfigured" signal. The token is never exposed on the
  # gateway — it stays inside the operator-managed pod env.
  GH_TOKEN: "CHANGE_ME_GH_TOKEN"
