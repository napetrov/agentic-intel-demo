# FILL IN before deploying — copy from this template

cluster_name: system-b

kubeconfig: ""   # path to kubeconfig for System B, empty = in-cluster

namespaces:
  services: system-b

# vLLM endpoint (canonical local-SLM path; see scripts/setup-system-b-vllm-local.sh).
# Same NodePort 30434 the historical ollama path used.
vllm_endpoint: "http://vllm.system-b.svc.cluster.local:8000"
vllm_nodeport: "30434"

# MinIO endpoints
minio_endpoint_internal: "http://minio.system-b.svc.cluster.local:9000"
minio_nodeport: "30900"   # port exposed on System B node, reachable from System A

# Offload-worker endpoint (System B execution backend)
offload_worker_endpoint: "http://offload-worker.system-b.svc.cluster.local:8080"

# External endpoint for the offload-worker (for control plane on System A)
offload_worker_external: "http://FILL_IN_SYSTEM_B_IP:30800"

# System B node address reachable from System A
system_b_node_ip: "FILL_IN_SYSTEM_B_IP"
